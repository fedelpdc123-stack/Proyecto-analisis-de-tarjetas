<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="Base de datos kaggel.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2315"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="transactions_data" custom_title="0" dock_id="1" table="4,17:maintransactions_data"/><dock_state state="000000ff00000000fd00000001000000020000024900000211fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000000002490000015c00ffffff000002490000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="cards_data" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="0"/></sort><column_widths><column index="1" value="50"/><column index="2" value="56"/><column index="3" value="85"/><column index="4" value="124"/><column index="5" value="132"/><column index="6" value="31"/><column index="7" value="58"/><column index="8" value="112"/><column index="9" value="78"/><column index="10" value="97"/><column index="11" value="138"/><column index="12" value="116"/><column index="13" value="85"/><column index="14" value="104"/><column index="15" value="133"/><column index="16" value="133"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="transactions_data" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="1" mode="1"/></sort><column_widths><column index="1" value="88"/><column index="2" value="117"/><column index="3" value="56"/><column index="4" value="50"/><column index="5" value="70"/><column index="6" value="148"/><column index="7" value="79"/><column index="8" value="179"/><column index="9" value="96"/><column index="10" value="62"/><column index="11" value="39"/><column index="12" value="163"/><column index="13" value="87"/><column index="14" value="85"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="users_data" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort><column index="0" mode="0"/></sort><column_widths><column index="1" value="56"/><column index="2" value="76"/><column index="3" value="95"/><column index="4" value="66"/><column index="5" value="78"/><column index="6" value="54"/><column index="7" value="257"/><column index="8" value="51"/><column index="9" value="62"/><column index="10" value="114"/><column index="11" value="89"/><column index="12" value="78"/><column index="13" value="77"/><column index="14" value="109"/><column index="15" value="102"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">ALTER TABLE cards_data ADD COLUMN expires_date TEXT;
UPDATE cards_data
SET expires_date = 
    CASE substr(expires, 5, 2)
	WHEN '21' THEN '2025'
        WHEN '22' THEN '2026'
        WHEN '23' THEN '2027'
        WHEN '24' THEN '2028'
        ELSE '20' || substr(expires, 5, 2)
    END
    || '-' ||
    CASE substr(expires, 1, 3)
        WHEN 'ene' THEN '01' WHEN 'feb' THEN '02' WHEN 'mar' THEN '03'
        WHEN 'abr' THEN '04' WHEN 'may' THEN '05' WHEN 'jun' THEN '06'
        WHEN 'jul' THEN '07' WHEN 'ago' THEN '08' WHEN 'sep' THEN '09'
        WHEN 'oct' THEN '10' WHEN 'nov' THEN '11' WHEN 'dic' THEN '12'
    END
    || '-01';</sql><sql name="Portfolio">-- PÁGINA 1 — Composición del Portfolio
SELECT card_brand, COUNT(*) AS cantidad,
       ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM cards_data), 1) AS pct
FROM cards_data
GROUP BY card_brand
ORDER BY cantidad DESC;

SELECT card_type, COUNT(*) AS cantidad
FROM cards_data
GROUP BY card_type;

SELECT ROUND(AVG(has_chip = 'YES') * 100, 1) AS pct_con_chip
FROM cards_data;</sql><sql name="Vencimientos">-- PÁGINA 2 — Vencimientos
SELECT
    CASE
        WHEN expires_date &lt; date('2026-01-01') THEN 'Vencida'
        WHEN strftime('%Y', expires_date) = strftime('%Y', date('2026-12-31')) THEN 'Vence este año'
        ELSE 'Vigente'
    END AS estado,
    COUNT(*) AS cantidad
FROM cards_data
GROUP BY estado;</sql><sql name="Limites">-- PÁGINA 3 — Límites de crédito
ALTER TABLE cards_data ADD COLUMN credit_limit_num REAL;

UPDATE cards_data
SET credit_limit_num = CAST(REPLACE(REPLACE(REPLACE(credit_limit, '$', ''), ' ', ''), '.', '') AS REAL);

SELECT card_type,
       ROUND(AVG(credit_limit_num), 0) AS limite_promedio
FROM cards_data
GROUP BY card_type
ORDER BY limite_promedio DESC;

</sql><sql name="antiguedad">-- PÁGINA 4 — Antigüedad de cuentas
UPDATE cards_data
SET acct_open_date = 'sep' || substr(acct_open_date, 5)
WHERE substr(acct_open_date, 1, 4) = 'sept';

UPDATE cards_data
SET acct_open_date_clean =
    CASE 
        WHEN CAST(substr(acct_open_date, 5, 2) AS INTEGER) &lt;= 25 
            THEN '20' || substr(acct_open_date, 5, 2)
        ELSE '19' || substr(acct_open_date, 5, 2)
    END
    || '-' ||
    CASE LOWER(TRIM(substr(acct_open_date, 1, 3)))
        WHEN 'ene' THEN '01' WHEN 'feb' THEN '02' WHEN 'mar' THEN '03'
        WHEN 'abr' THEN '04' WHEN 'may' THEN '05' WHEN 'jun' THEN '06'
        WHEN 'jul' THEN '07' WHEN 'ago' THEN '08' WHEN 'sep' THEN '09'
        WHEN 'oct' THEN '10' WHEN 'nov' THEN '11' WHEN 'dic' THEN '12'
    END
    || '-01';

SELECT strftime('%Y', acct_open_date_clean) AS año_apertura,
       COUNT(*) AS tarjetas,
       ROUND(AVG(credit_limit_num), 0) AS limite_promedio
FROM cards_data
GROUP BY año_apertura
ORDER BY año_apertura;</sql><sql name="PIN">-- PÁGINA 5 — Seguridad del PIN
SELECT
    COUNT(CASE 
        WHEN (CAST(strftime('%Y','now') AS INTEGER) - CAST(year_pin_last_changed AS INTEGER)) &gt; 10 
        THEN 1 END) AS sin_cambio_10_anos,

    COUNT(CASE 
        WHEN (CAST(strftime('%Y','now') AS INTEGER) - CAST(year_pin_last_changed AS INTEGER)) &gt; 15 
        THEN 1 END) AS sin_cambio_15_anos,

    ROUND(AVG(CAST(strftime('%Y','now') AS INTEGER) - CAST(year_pin_last_changed AS INTEGER)), 1) AS promedio_anos
FROM cards_data;</sql><sql name="Perfil financiero">-- PÁGINA 6 — Perfil financiero (percentil simulado)
ALTER TABLE users_data ADD COLUMN total_debt_clean REAL;

UPDATE users_data
SET total_debt_clean = CAST(REPLACE(REPLACE(REPLACE(total_debt, '$', ''), ' ', ''), '.', '') AS REAL);

WITH ordered AS (
    SELECT yearly_income,
           ROW_NUMBER() OVER (ORDER BY yearly_income) AS rn,
           COUNT(*) OVER () AS total
    FROM users_data
),
percentiles AS (
    SELECT
        MAX(CASE WHEN rn &lt;= total * 0.33 THEN yearly_income END) AS p33,
        MAX(CASE WHEN rn &lt;= total * 0.66 THEN yearly_income END) AS p66
    FROM ordered
),
segmentados AS (
    SELECT u.*,
           CASE
               WHEN u.yearly_income &lt; p.p33 THEN 'Bajo'
               WHEN u.yearly_income &lt; p.p66 THEN 'Medio'
               ELSE 'Alto'
           END AS segmento
    FROM users_data u, percentiles p
)
SELECT segmento,
       ROUND(AVG(total_debt_clean), 0) AS deuda_promedio,
       ROUND(AVG(credit_score), 0) AS score_promedio
FROM segmentados
GROUP BY segmento;</sql><sql name="Transacciones">-- PÁGINA 7 — Transacciones por mes
ALTER TABLE transactions_data ADD COLUMN amount_clean REAL;

UPDATE transactions_data
SET amount_clean = CAST(REPLACE(REPLACE(REPLACE(amount, '$', ''), ' ', ''), '.', '') AS REAL);

ALTER TABLE transactions_data
ADD COLUMN date_clean TEXT;

UPDATE transactions_data
SET date_clean =
    substr(date, instr(date, '/') + instr(substr(date, instr(date, '/') + 1), '/') + 1, 4) || '-' ||  -- año
    printf('%02d',
        substr(date,
            instr(date, '/') + 1,
            instr(substr(date, instr(date, '/') + 1), '/') - 1
        )
    ) || '-' ||  -- mes
    printf('%02d',
        substr(date, 1, instr(date, '/') - 1)
    );
	
SELECT strftime('%Y-%m', date_clean) AS mes,
       COUNT(*) AS transacciones,
       ROUND(AVG(amount_clean), 2) AS gasto_promedio
FROM transactions_data
GROUP BY mes
ORDER BY mes;

-- Gasto y errores por segmento
ALTER TABLE users_data ADD COLUMN yearly_income_clean REAL;

UPDATE users_data
SET yearly_income_clean = CAST(REPLACE(REPLACE(REPLACE(yearly_income, '$', ''), ' ', ''), '.', '') AS REAL);


WITH seg AS (
    SELECT client_id,
           CASE
               WHEN yearly_income_clean &lt; 35298 THEN 'Bajo'
               WHEN yearly_income_clean &lt; 47980 THEN 'Medio'
               ELSE 'Alto'
           END AS segmento
    FROM users_data
)
SELECT seg.segmento,
       ROUND(AVG(t.amount_clean), 2) AS gasto_promedio,
       ROUND(AVG(CASE WHEN t.errors IS NOT NULL AND t.errors &lt;&gt; '' THEN 1.0 ELSE 0 END) * 100, 2) AS pct_errores
FROM transactions_data t
JOIN seg ON t.client_id = seg.client_id
GROUP BY seg.segmento;</sql><sql name="Tarjetas y pins vencidos">-- PÁGINA 8 — Riesgo cruzado

WITH riesgo AS (
    SELECT client_id,
           MAX(CASE 
               WHEN expires_date &lt; DATE('2026-01-01') THEN 1 
               ELSE 0 
           END) AS tarjeta_vencida, 

           MAX(CASE 
               WHEN (CAST(strftime('%Y', '2026-01-01') AS INTEGER) - year_pin_last_changed) &gt; 10 
               THEN 1 
               ELSE 0 
           END) AS pin_viejo
    FROM cards_data
    GROUP BY client_id
)
SELECT * FROM riesgo;</sql><sql name="Clientes de riesgo">WITH riesgo AS (
    SELECT client_id,
           MAX(CASE WHEN expires_date &lt; date('2026-01-01') THEN 1 ELSE 0 END) AS tiene_vencida,
           MAX(CASE 
               WHEN (CAST(strftime('%Y', '2026-01-01') AS INTEGER) - year_pin_last_changed) &gt; 10 
               THEN 1 ELSE 0 
           END) AS pin_viejo
    FROM cards_data
    GROUP BY client_id
),
clasificado AS (
    SELECT client_id,
           CASE 
               WHEN tiene_vencida = 1 AND pin_viejo = 1 THEN 'Alto Riesgo'
               ELSE 'Bajo Riesgo'
           END AS tipo
    FROM riesgo
)
SELECT tipo, 
       COUNT(*) AS clientes,
       ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM clasificado), 2) AS pct
FROM clasificado
GROUP BY tipo;</sql><current_tab id="9"/></tab_sql></sqlb_project>
